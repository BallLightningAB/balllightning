{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "src/**",
      ".vscode/**",
      "index.html",
      "vite.config.ts",
      "!node_modules",
      "!.git",
      "!dist",
      "!build",
      "!.vercel",
      "!src/paraglide",
      "!src/routeTree.gen.ts",
      "!src/components/ui/arrow-left.tsx",
      "!src/components/ui/arrow-right.tsx",
      "!src/components/ui/at-sign.tsx",
      "!src/components/ui/earth.tsx",
      "!src/components/ui/folder-code.tsx",
      "!src/components/ui/github.tsx",
      "!src/components/ui/link.tsx",
      "!src/components/ui/linkedin.tsx",
      "!src/components/ui/map-pin.tsx",
      "!src/components/ui/shield-check.tsx",
      "!src/components/ui/webhook.tsx",
      "!src/components/ui/x.tsx",
      "!src/styles.css",
      "!specs/archived",
      "!**/*.md",
      "!**/*.mdx",
      "!**/*.yaml",
      "!**/*.yml"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "tab"
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "security": {
        "noDangerouslySetInnerHtml": "off"
      },
      "nursery": {
        "useSortedClasses": "off",
        "useConsistentArrowReturn": "off"
      },
      "style": {
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "filenameCases": ["kebab-case", "PascalCase"]
          }
        },
        "useImportType": "off",
        "noNegationElse": "off"
      },
      "performance": {
        "noNamespaceImport": "off"
      },
      "a11y": {
        "useGenericFontNames": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "extends": ["ultracite/core", "ultracite/remix"]
}
